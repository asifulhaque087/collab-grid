# Keep the build context lean — dependencies and artifacts are rebuilt in-image.
**/node_modules
**/.next
**/dist
**/.turbo
**/coverage
**/out
**/build

# Local env + secrets (compose injects env at runtime instead)
**/.env
**/.env.*

# VCS + tooling
.git
.gitignore
.vscode
.idea

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Repo docs / scratch not needed by the build
prototypes
*.md
**/*.md
.claude
context

# Misc
.DS_Store
*.pem
Dockerfile
**/Dockerfile
.dockerignore
docker-compose.yml
